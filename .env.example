# ─────────────────────────────────────────────────────────────────────
# KATHA-AI environment template.
# Copy to .env and fill in real values. NEVER commit .env to git.
# Stage 0 hardening: app refuses to start in staging/prod with default
# secrets. See backend/app/config.py: Settings.assert_production_safe.
# ─────────────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────
ENVIRONMENT=dev          # dev | staging | prod
DEBUG=true               # true in dev only — JSON logs in prod
APP_NAME="KATHA AI"

# ── Database ─────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://katha:katha@localhost:5432/katha
DATABASE_ECHO=false

# ── Redis / Celery ───────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── LLM: Anthropic Claude (PRIMARY agent runtime, Stage 2+) ─────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# ── LLM: OpenAI (fallback + embeddings) ─────────────
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── LLM: Google Gemini (image generation) ───────────
GEMINI_API_KEY=

# ── External APIs ───────────────────────────────────
YOUTUBE_API_KEY=

# ── Feature Flags ───────────────────────────────────
SORA_ENABLED=false

# ── Storage (Cloudflare R2 / S3-compat) ─────────────
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=katha-assets
S3_REGION=auto

# ── Auth ────────────────────────────────────────────
# In prod: generate with `python -c "import secrets; print(secrets.token_urlsafe(48))"`
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ── Frontend ────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
