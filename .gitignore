# ── Dependencies & build ────────────────────────────────────────────────────
.next/
node_modules/
.venv/
__pycache__/
.pytest_cache/
dist/
build/
*.pyc
*.egg-info/
.mypy_cache/
.ruff_cache/
pnpm-lock.yaml
package-lock.json

# ── Environment & secrets ───────────────────────────────────────────────────
.env
.env.*
!.env.example

# ── Editor / OS / local tooling ─────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# ── Claude Code local settings (per-machine, not for repo) ──────────────────
.claude/settings.local.json
**/.claude/settings.local.json
.claude/
**/.claude/

# ── Logs (runtime, may contain stack traces / secrets) ──────────────────────
*.log
logs/
backend-start.log
frontend-start.log
frontend-error.log

# ── Build caches & incremental artifacts ────────────────────────────────────
*.tsbuildinfo
frontend/tsconfig.tsbuildinfo
.turbo/
.cache/
coverage/

# ── Scratch / runtime output directories ────────────────────────────────────
tmp/
tmp_*/
tmp_diagrams/
tmp_exports/
generated/
# Only ignore the project-root upload dir (Stage 7's local storage
# backend writes here). The Python package
# ``backend/app/repositories/uploads`` is source code and must NOT
# match this pattern — leading ``/`` anchors to repo root.
/uploads/
/backend/uploads/

# ── Database / local storage ────────────────────────────────────────────────
*.sqlite
*.sqlite3
*.db
